{
    "name": "master3395/mas-authhub",
    "description": "MAS AuthHub identity module for CMS Made Simple",
    "require": {
        "php": ">=7.4",
        "league/oauth2-client": "^2.7",
        "firebase/php-jwt": "^5.6|^6.4",
        "onelogin/php-saml": "^4.2",
        "web-auth/webauthn-lib": "^3.3",
        "web-auth/cose-lib": "^3.3"
    },
    "config": {
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
    }
